.sc-posterior{background:rgba(210,232,255,.08);border:1px solid rgba(210,232,255,.25)}
.sc-posterior::before{background:var(--blue)}
.sc-brown{background:rgba(107,61,50,.3);border:1px solid rgba(107,61,50,.6)}
.sc-brown::before{background:var(--maroon-light)}

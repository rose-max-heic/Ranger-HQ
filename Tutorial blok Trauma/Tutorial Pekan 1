body{font-family:'DM Sans',sans-serif;background:var(--maroon-dark);color:var(--cream);min-height:100vh;overflow-x:hidden}
.hero{background:linear-gradient(135deg,var(--maroon-dark) 0%,var(--maroon) 50%,#5a2e22 100%);padding:60px 24px 40px;text-align:center;position:relative;overflow:hidden;border-bottom:3px solid var(--orange)}
.hero::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(ellipse at 30% 40%,rgba(251,77,0,.08) 0%,transparent 60%),radial-gradient(ellipse at 70% 60%,rgba(210,232,255,.05) 0%,transparent 50%);pointer-events:none}
.hero-badge{display:inline-block;background:var(--orange);color:#fff;font-family:'DM Mono',monospace;font-size:11px;letter-spacing:2px;padding:5px 14px;border-radius:20px;margin-bottom:20px;text-transform:uppercase}
.hero h1{font-family:'Playfair Display',serif;font-size:clamp(2rem,5vw,3.5rem);font-weight:900;line-height:1.1;color:var(--cream);margin-bottom:12px}
.hero h1 span{color:var(--orange);font-style:italic}
.hero-sub{font-size:1rem;color:var(--blue);opacity:.85;max-width:600px;margin:0 auto 30px;line-height:1.6}
.hero-stats{display:flex;justify-content:center;gap:24px;flex-wrap:wrap}
.stat-pill{background:rgba(240,232,159,.1);border:1px solid rgba(240,232,159,.25);padding:8px 18px;border-radius:30px;font-size:13px;color:var(--cream)}
.stat-pill strong{color:var(--orange)}
.nav-tabs{position:sticky;top:0;z-index:100;background:var(--maroon-dark);border-bottom:2px solid rgba(251,77,0,.3);display:flex;overflow-x:auto;scrollbar-width:none;padding:0 16px;gap:4px}
.nav-tabs::-webkit-scrollbar{display:none}
.tab-btn{flex-shrink:0;background:none;border:none;border-bottom:3px solid transparent;color:rgba(240,232,159,.5);font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;padding:14px 16px;cursor:pointer;transition:all .25s;white-space:nowrap}
.tab-btn:hover{color:var(--cream)}
.tab-btn.active{color:var(--orange);border-bottom-color:var(--orange)}
.section{display:none;padding:32px 16px;max-width:900px;margin:0 auto;animation:fadeIn .35s ease}
.section.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
.section-title{font-family:'Playfair Display',serif;font-size:clamp(1.5rem,3vw,2rem);color:var(--cream);margin-bottom:24px;padding-bottom:12px;border-bottom:2px solid var(--orange);display:flex;align-items:center;gap:12px}
.section-title .icon{width:36px;height:36px;background:var(--orange);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.card{background:rgba(66,37,29,.5);border:1px solid rgba(240,232,159,.12);border-radius:12px;padding:20px;margin-bottom:16px;transition:border-color .2s}
.card:hover{border-color:rgba(251,77,0,.4)}
.card-title{font-family:'Playfair Display',serif;font-size:1.1rem;color:var(--cream);margin-bottom:10px;display:flex;align-items:center;gap:8px}
.card p,.card li{font-size:14px;line-height:1.75;color:rgba(240,232,159,.85)}

.option.wrong{background:rgba(192,57,43,.2);border-color:#c0392b;color:#ffaaaa}
.option-letter{font-family:'DM Mono',monospace;font-weight:700;color:var(--orange);flex-shrink:0;width:16px}
.explanation{margin-top:12px;padding:12px;background:rgba(39,174,96,.1);border:1px solid rgba(39,174,96,.3);border-radius:8px;font-size:13px;line-height:1.7;color:rgba(240,232,159,.9);display:none}
.explanation.show{display:block}
.quiz-btn{margin-top:14px;background:var(--orange);color:#fff;border:none;padding:9px 20px;border-radius:6px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:background .2s}
.quiz-btn:hover{background:#e04400}
.score-display{text-align:center;padding:20px;background:rgba(66,37,29,.5);border:1px solid var(--orange);border-radius:12px;margin-bottom:20px}
.score-num{font-family:'Playfair Display',serif;font-size:3rem;color:var(--orange)}
.flow-steps{display:flex;flex-direction:column;gap:4px;margin:12px 0}
.flow-step{display:flex;align-items:center;gap:10px;padding:10px 14px;background:rgba(66,37,29,.4);border-radius:8px;font-size:13px;line-height:1.5;color:rgba(240,232,159,.85);position:relative}
.flow-step::after{content:'▼';position:absolute;bottom:-12px;left:50%;transform:translateX(-50%);font-size:10px;color:var(--orange);z-index:1}

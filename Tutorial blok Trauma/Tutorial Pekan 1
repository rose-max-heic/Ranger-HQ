  <div class="quiz-card" data-correct="b">
    <div class="quiz-num">Soal 01 — Patofisiologi</div>
    <div class="quiz-q">Berapa lama proses nekrosis yang terjadi pada kasus cedera medula spinalis?</div>
    <div class="options">
      <button class="option" onclick="answer(this,'a','b')"><span class="option-letter">A.</span>12 jam</button>
      <button class="option" onclick="answer(this,'b','b')"><span class="option-letter">B.</span>72 jam</button>
      <button class="option" onclick="answer(this,'c','b')"><span class="option-letter">C.</span>1 jam</button>
      <button class="option" onclick="answer(this,'d','b')"><span class="option-letter">D.</span>6 jam</button>
      <button class="option" onclick="answer(this,'e','b')"><span class="option-letter">E.</span>24 jam</button>
    </div>
    <div class="explanation">Jawaban B: 72 jam. Proses nekrosis pada SCI berlangsung dalam 72 jam (3 hari) setelah cedera. Inilah mengapa window treatment sangat penting. Inflamasi puncak di hari 2-3, sehingga methylprednisolone paling efektif diberikan dalam 8 jam pertama.</div>
  </div>

  <div class="quiz-card" data-correct="c">
    <div class="quiz-num">Soal 02 — Fraktur Spinal</div>
    <div class="quiz-q">Jenis fraktur apakah yang terjadi akibat benturan pada puncak kepala dan menyebabkan fraktur pada arcus posterior vertebra C1?</div>
    <div class="options">
      <button class="option" onclick="answer(this,'a','c')"><span class="option-letter">A.</span>Slice fraktur</button>
      <button class="option" onclick="answer(this,'b','c')"><span class="option-letter">B.</span>Wedge fraktur</button>
      <button class="option" onclick="answer(this,'c','c')"><span class="option-letter">C.</span>Jefferson fraktur</button>
      <button class="option" onclick="answer(this,'d','c')"><span class="option-letter">D.</span>Fraktur Hangman</button>
      <button class="option" onclick="answer(this,'e','c')"><span class="option-letter">E.</span>Burst fraktur umum</button>
    </div>
    <div class="explanation">Jawaban C: Jefferson Fraktur. Spesifik burst fracture pada C1 (atlas) akibat kompresi aksial dari puncak kepala. Arcus anterior dan posterior C1 retak bilateral. Mekanisme: menyelam ke kolam dangkal, jatuh menimpa kepala.</div>
  </div>

  <div class="quiz-card" data-correct="a">
    <div class="quiz-num">Soal 03 — Klasifikasi Defisit</div>
    <div class="quiz-q">Manakah gangguan yang dapat timbul bila terdapat cedera medula spinalis komplit setingkat Lumbal 1?</div>
    <div class="options">
      <button class="option" onclick="answer(this,'a','a')"><span class="option-letter">A.</span>Paraplegia</button>
      <button class="option" onclick="answer(this,'b','a')"><span class="option-letter">B.</span>Quadriplegia</button>
      <button class="option" onclick="answer(this,'c','a')"><span class="option-letter">C.</span>Hemiparesis</button>
      <button class="option" onclick="answer(this,'d','a')"><span class="option-letter">D.</span>Hemiplegia</button>
      <button class="option" onclick="answer(this,'e','a')"><span class="option-letter">E.</span>Penurunan kesadaran</button>
    </div>
    <div class="explanation">Jawaban A: Paraplegia. Cedera L1 → kelumpuhan kedua tungkai (paraplegia), bukan keempat ekstremitas. Quadriplegia terjadi pada cedera servikal. Hemiplegia biasanya dari lesi otak, bukan SCI murni.</div>
  </div>

  <div class="quiz-card" data-correct="b">
    <div class="quiz-num">Soal 04 — Tatalaksana Farmakologi</div>
    <div class="quiz-q">Manakah pernyataan yang benar mengenai penatalaksanaan farmakologis cedera medula spinalis berdasarkan AO Spine 2017?</div>
    <div class="options">
      <button class="option" onclick="answer(this,'a','b')"><span class="option-letter">A.</span>Tidak direkomendasikan diberi Methyl Prednisolon sama sekali</button>
      <button class="option" onclick="answer(this,'b','b')"><span class="option-letter">B.</span>Pemberian Metil Prednisolon, bila onset dari 3-8 jam, diberikan selama 24 jam</button>
      <button class="option" onclick="answer(this,'c','b')"><span class="option-letter">C.</span>Pemberian Metil Prednisolon, bila onset lebih dari 3 jam, diberikan selama 24 jam</button>
      <button class="option" onclick="answer(this,'d','b')"><span class="option-letter">D.</span>Pemberian Metil Prednisolon, bila onset kurang dari 3 jam, diberikan selama 24 jam</button>
      <button class="option" onclick="answer(this,'e','b')"><span class="option-letter">E.</span>Pemberian Metil Prednisolon, bila onset kurang dari 3 jam, tidak direkomendasikan</button>
    </div>
    <div class="explanation">Jawaban B. AO Spine 2017: MPSS "dapat ditawarkan" jika onset kurang dari 8 jam. Untuk onset 3-8 jam → infus 24 jam. Kunci: window &lt;8 jam dan durasi 24 jam!</div>
  </div>

  <div class="quiz-card" data-correct="c">
    <div class="quiz-num">Soal 05 — Fraktur Spinal</div>
    <div class="quiz-q">Disebut apakah fraktur yang mengenai ligamentum posterior dan menyebabkan kompresi ke arah anterior?</div>
    <div class="options">
      <button class="option" onclick="answer(this,'a','c')"><span class="option-letter">A.</span>Cedera ekstensi</button>
      <button class="option" onclick="answer(this,'b','c')"><span class="option-letter">B.</span>Burst fraktur</button>
      <button class="option" onclick="answer(this,'c','c')"><span class="option-letter">C.</span>Slice fraktur</button>
      <button class="option" onclick="answer(this,'d','c')"><span class="option-letter">D.</span>Cedera kompresi vertikal</button>
      <button class="option" onclick="answer(this,'e','c')"><span class="option-letter">E.</span>Wedge fraktur</button>
    </div>
    <div class="explanation">Jawaban C: Slice Fraktur. Terjadi akibat fleksi + rotasi → ligamentum posterior robek → fragmen anterior mengiris ke anterior → kompresi ke arah anterior. Fraktur TIDAK STABIL karena ligamentum posterior rusak.</div>
  </div>

  <div class="quiz-card" data-correct="b">
    <div class="quiz-num">Soal 06 — Klasifikasi ASIA</div>
    <div class="quiz-q">Laki-laki 45 tahun jatuh dari pohon. Fungsi sensorik masih baik. Fungsi motorik terganggu pada segmen sakral S4-5. Berdasarkan ASIA/IMSOP, masuk grade berapa?</div>
    <div class="options">
      <button class="option" onclick="answer(this,'a','b')"><span class="option-letter">A.</span>Grade C</button>
      <button class="option" onclick="answer(this,'b','b')"><span class="option-letter">B.</span>Grade B</button>
      <button class="option" onclick="answer(this,'c','b')"><span class="option-letter">C.</span>Grade E</button>
      <button class="option" onclick="answer(this,'d','b')"><span class="option-letter">D.</span>Grade D</button>
      <button class="option" onclick="answer(this,'e','b')"><span class="option-letter">E.</span>Grade A</button>
    </div>
    <div class="explanation">Jawaban B: Grade B. Grade B = Incomplete: sensorik masih ada, motorik TIDAK ada di S4-S5. Grade C = motorik ada tapi &lt;grade 3. Grade D = motorik ada &ge;grade 3. Grade A = tidak ada sama sekali.</div>
  </div>

  <div class="quiz-card" data-correct="d">
    <div class="quiz-num">Soal 07 — Sindrom SCI</div>
    <div class="quiz-q">Disebut sindrom apakah bila terjadi kerusakan pada sensori dan lumpuh flaccid pada ekstremitas bawah serta kontrol berkemih dan defekasi pada trauma medulla spinalis?</div>
    <div class="options">
      <button class="option" onclick="answer(this,'a','d')"><span class="option-letter">A.</span>Anterior cord syndrome</button>
      <button class="option" onclick="answer(this,'b','d')"><span class="option-letter">B.</span>Central cord syndrome</button>
      <button class="option" onclick="answer(this,'c','d')"><span class="option-letter">C.</span>Brown-Sequard Syndrome</button>
      <button class="option" onclick="answer(this,'d','d')"><span class="option-letter">D.</span>Cauda equina syndrome</button>
      <button class="option" onclick="answer(this,'e','d')"><span class="option-letter">E.</span>Posterior cord syndrome</button>
    </div>
    <div class="explanation">Jawaban D: Cauda Equina Syndrome. Khas: paralisis FLAKSID (LMN!) pada tungkai bawah, gangguan kontrol bladder/bowel, anestesi saddle. Flaksid karena ini bukan medula spinalis, tapi akar saraf yang terkena → LMN pure.</div>
  </div>

  <div class="quiz-card" data-correct="a">
    <div class="quiz-num">Soal 08 — Tatalaksana Awal</div>
    <div class="quiz-q">Manakah terapi penanganan awal pada penderita dengan kecurigaan cedera medula spinalis?</div>
    <div class="options">
      <button class="option" onclick="answer(this,'a','a')"><span class="option-letter">A.</span>Steroid</button>
      <button class="option" onclick="answer(this,'b','a')"><span class="option-letter">B.</span>NSAID</button>
      <button class="option" onclick="answer(this,'c','a')"><span class="option-letter">C.</span>Antibiotik</button>
      <button class="option" onclick="answer(this,'d','a')"><span class="option-letter">D.</span>Anti konvulsan</button>
      <button class="option" onclick="answer(this,'e','a')"><span class="option-letter">E.</span>Analgetik</button>
    </div>
    <div class="explanation">Jawaban A: Steroid (methylprednisolone) untuk mengurangi inflamasi sekunder pada SCI akut. Ingat: imobilisasi dan stabilisasi airway harus dilakukan lebih dulu secara prioritas, tapi dalam konteks pilihan farmakologi → steroid adalah jawabannya.</div>
  </div>

  <div class="quiz-card" data-correct="c">
    <div class="quiz-num">Soal 09 — Sindrom SCI</div>
    <div class="quiz-q">Laki-laki 45 tahun jatuh dari pohon. Kelemahan motorik lengan lebih berat dari tungkai. Baal di bawah leher. Tidak bisa menahan kencing. Terdapat sacral sparing. Diagnosa paling tepat?</div>
    <div class="options">
      <button class="option" onclick="answer(this,'a','c')"><span class="option-letter">A.</span>Cauda equina syndrome</button>
      <button class="option" onclick="answer(this,'b','c')"><span class="option-letter">B.</span>Brown sequard syndrome</button>
      <button class="option" onclick="answer(this,'c','c')"><span class="option-letter">C.</span>Central cord syndrome</button>
      <button class="option" onclick="answer(this,'d','c')"><span class="option-letter">D.</span>Conus medullaris syndrome</button>
      <button class="option" onclick="answer(this,'e','c')"><span class="option-letter">E.</span>Posterior cord syndrome</button>
    </div>
    <div class="explanation">Jawaban C: Central Cord Syndrome. Dua clue: (1) Lengan lebih lemah dari tungkai — khas Central Cord karena traktus kortikospinal untuk lengan ada di bagian lebih sentral; (2) Sacral sparing — serabut sakral di perifer terlindungi. Ini sindrom SCI inkomplet paling umum!</div>
  </div>

  <div class="quiz-card" data-correct="d">
    <div class="quiz-num">Soal 10 — Brown-Sequard</div>
    <div class="quiz-q">Laki-laki 20 tahun, luka tusuk punggung. Mengeluh lengan dan tungkai kiri sulit digerakkan. Kebas dari lengan kanan hingga kaki kanan. Neurologis: hemiparesis sinistra + hipoestesia sisi kanan tubuh. Mekanisme trauma yang paling mungkin?</div>
    <div class="options">
      <button class="option" onclick="answer(this,'a','d')"><span class="option-letter">A.</span>Kerusakan columna posterior medula spinalis akibat tusukan</button>
      <button class="option" onclick="answer(this,'b','d')"><span class="option-letter">B.</span>Hemiseksi medula spinalis sisi kanan akibat tusukan</button>
      <button class="option" onclick="answer(this,'c','d')"><span class="option-letter">C.</span>Kerusakan columna anterior medula spinalis akibat tusukan</button>
      <button class="option" onclick="answer(this,'d','d')"><span class="option-letter">D.</span>Hemiseksi medula spinalis sisi kiri akibat tusukan</button>
      <button class="option" onclick="answer(this,'e','d')"><span class="option-letter">E.</span>Penusukan menyebabkan disrupsi pembuluh darah → iskemik central medula spinalis</button>
    </div>
    <div class="explanation">Jawaban D: Hemiseksi medula spinalis sisi kiri. Brown-Sequard: lesi kiri → motorik + propriosepsi hilang di KIRI (ipsilateral), nyeri + suhu hilang di KANAN (kontralateral, karena spinotalamikus sudah menyeberang). Pasien: hemiparesis sinistra + hipoestesia dextra → lesi di KIRI.</div>
  </div>

  <div class="quiz-card" data-correct="c">
    <div class="quiz-num">Soal 11 — Interpretasi Kasus</div>
    <div class="quiz-q">Pada skenario kasus (fraktur C4-C6, kekuatan 2/2 atas dan 2/1 bawah, hipoestesia bawah C5, gangguan propriosepsi), diagnosis yang paling sesuai adalah?</div>
    <div class="options">
      <button class="option" onclick="answer(this,'a','c')"><span class="option-letter">A.</span>Complete SCI grade A</button>
      <button class="option" onclick="answer(this,'b','c')"><span class="option-letter">B.</span>Anterior cord syndrome</button>
      <button class="option" onclick="answer(this,'c','c')"><span class="option-letter">C.</span>Central cord syndrome dengan incomplete SCI</button>
      <button class="option" onclick="answer(this,'d','c')"><span class="option-letter">D.</span>Cauda equina syndrome</button>
      <button class="option" onclick="answer(this,'e','c')"><span class="option-letter">E.</span>Brown-Sequard syndrome</button>
    </div>
    <div class="explanation">Jawaban C: Central cord syndrome dengan incomplete SCI. Clue: (1) Masih ada gerakan (skor 2) → incomplete; (2) Cedera servikal + fraktur C4-C6 (mekanisme hiperekstensi pada C-spine); (3) Propriosepsi terganggu (kolumna dorsal ikut terlibat); (4) GCS 15 = otak baik = lesi hanya di spinal.</div>
  </div>

  <div class="quiz-card" data-correct="b">
    <div class="quiz-num">Soal 12 — Spinal Shock</div>
    <div class="quiz-q">Pasien SCI akut datang dengan arefleksia, flaksid, dan retensi urin. Tidak ada klonus dan refleks patologis negatif. Kondisi ini paling tepat disebut?</div>
    <div class="options">
      <button class="option" onclick="answer(this,'a','b')"><span class="option-letter">A.</span>Syok hipovolemik</button>
      <button class="option" onclick="answer(this,'b','b')"><span class="option-letter">B.</span>Spinal shock</button>
      <button class="option" onclick="answer(this,'c','b')"><span class="option-letter">C.</span>Syok septik</button>
      <button class="option" onclick="answer(this,'d','b')"><span class="option-letter">D.</span>Fase kronik SCI</button>
      <button class="option" onclick="answer(this,'e','b')"><span class="option-letter">E.</span>Cedera LMN murni</button>
    </div>
    <div class="explanation">Jawaban B: Spinal Shock. Spinal shock = hilangnya SEMUA fungsi neurologis akibat SCI akut. Ditandai: arefleksia, flaksid, retensi urin/feses, tidak ada refleks patologis. Fase sementara — akan menjadi spastik dan hiperrefleks setelah fase akut berlalu!</div>
  </div>

  <div class="quiz-card" data-correct="a">
    <div class="quiz-num">Soal 13 — Anatomi Klinis</div>
    <div class="quiz-q">Pasien SCI setingkat C4 datang dengan distress nafas. Penyebab utama gangguan nafas adalah?</div>
    <div class="options">
      <button class="option" onclick="answer(this,'a','a')"><span class="option-letter">A.</span>Kelemahan diafragma akibat gangguan nervus phrenicus (C3-C5)</button>
      <button class="option" onclick="answer(this,'b','a')"><span class="option-letter">B.</span>Pneumotoraks akibat fraktur iga</button>
      <button class="option" onclick="answer(this,'c','a')"><span class="option-letter">C.</span>Edema paru neurogenik</button>
      <button class="option" onclick="answer(this,'d','a')"><span class="option-letter">D.</span>Obstruksi jalan nafas atas</button>
      <button class="option" onclick="answer(this,'e','a')"><span class="option-letter">E.</span>Gangguan pergerakan iga oleh saraf torakal</button>
    </div>
    <div class="explanation">Jawaban A: Nervus phrenicus (C3-C5) mengontrol kontraksi diafragma — otot utama pernafasan. Cedera C4 → ganggu N. phrenicus → diafragma tidak bisa berkontraksi → gagal nafas. Semakin tinggi level SCI servikal → semakin besar risiko gagal nafas. C3 ke atas = butuh ventilator!</div>
  </div>

  <div style="text-align:center;margin-top:20px">
    <button class="quiz-btn" onclick="showScore()" style="padding:12px 32px;font-size:15px">Lihat Skor Total</button>
    <button class="quiz-btn" onclick="resetQuiz()" style="background:#6b3d32;margin-left:10px;padding:12px 32px;font-size:15px">Reset Soal</button>
  </div>
</div>

<div class="footer">
  <p>Traumatologi Blok 1 · Spinal Cord Injury · Panduan Komprehensif</p>
  <p style="margin-top:6px">Semoga nilainya bagus dan ilmunya bermanfaat!</p>
</div>

<script>
function showTab(name,btn){
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('tab-'+name).classList.add('active');
  btn.classList.add('active');
}
function toggleAcc(header){
  const body=header.nextElementSibling;
  const arrow=header.querySelector('.accordion-arrow');
  body.classList.toggle('open');
  arrow.classList.toggle('open');
}
let answered={},correct=0,total=0;
function answer(btn,chosen,correctAns){
  const card=btn.closest('.quiz-card');
  const cardId=Array.from(document.querySelectorAll('.quiz-card')).indexOf(card);
  if(answered[cardId])return;
  answered[cardId]=true;
  total++;
  const buttons=card.querySelectorAll('.option');
  buttons.forEach(b=>{
    b.style.pointerEvents='none';
    const letter=b.querySelector('.option-letter').textContent.replace('.','').toLowerCase();
    if(letter===correctAns)b.classList.add('correct');
    else if(letter===chosen&&chosen!==correctAns)b.classList.add('wrong');
  });
  if(chosen===correctAns)correct++;
  card.querySelector('.explanation').classList.add('show');
}
function showScore(){
  const panel=document.getElementById('score-panel');
  panel.style.display='block';
  document.getElementById('score-val').textContent=correct+'/'+total;
  const pct=total>0?(correct/total*100):0;
  let msg='';
  if(pct===100)msg='Sempurna! Kamu siap ujian!';
  else if(pct>=80)msg='Bagus banget! Hampir sempurna!';
  else if(pct>=60)msg='Cukup baik! Review bagian yang kurang ya!';
  else msg='Yuk review lagi materinya, kamu pasti bisa!';
  document.getElementById('score-msg').textContent=msg;
  panel.scrollIntoView({behavior:'smooth',block:'center'});
}
function resetQuiz(){
  answered={};correct=0;total=0;
  document.querySelectorAll('.option').forEach(b=>{b.classList.remove('correct','wrong');b.style.pointerEvents='';});
  document.querySelectorAll('.explanation').forEach(e=>e.classList.remove('show'));
  document.getElementById('score-panel').style.display='none';
}
</script>
</body>
</html>

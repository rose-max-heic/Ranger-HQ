.asia-row{display:flex;gap:8px;margin-bottom:8px;align-items:flex-start}
.asia-grade{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-family:'DM Mono',monospace;font-size:14px;flex-shrink:0}

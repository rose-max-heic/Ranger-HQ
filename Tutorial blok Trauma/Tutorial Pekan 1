.pearl strong{color:var(--orange)}
.pearl .pearl-label{font-family:'DM Mono',monospace;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--orange);display:block;margin-bottom:6px}
.note-box{background:rgba(210,232,255,.08);border:1px solid rgba(210,232,255,.25);border-radius:8px;padding:12px 14px;font-size:13px;line-height:1.7;color:var(--blue);margin:10px 0}
.warn-box{background:rgba(240,232,159,.08);border:1px solid rgba(240,232,159,.3);border-radius:8px;padding:12px 14px;font-size:13px;line-height:1.7;color:var(--cream);margin:10px 0}

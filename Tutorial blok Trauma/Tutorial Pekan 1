.syndrome-name{font-family:'Playfair Display',serif;font-size:1rem;color:var(--cream);margin-bottom:8px}
.syndrome-key{font-size:12px;font-weight:700;font-family:'DM Mono',monospace;color:var(--orange);margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px}
.syndrome-desc{font-size:12.5px;line-height:1.6;color:rgba(240,232,159,.8)}

.fracture-item:hover{border-color:rgba(251,77,0,.35)}
.frac-icon{width:44px;height:44px;border-radius:8px;background:var(--maroon);display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;border:1px solid rgba(251,77,0,.3)}
.frac-content{flex:1}
.frac-name{font-family:'Playfair Display',serif;font-size:1rem;color:var(--cream);margin-bottom:4px}
.frac-mechanism{font-size:12px;color:var(--orange);font-weight:600;font-family:'DM Mono',monospace;margin-bottom:6px;letter-spacing:.3px}
.frac-desc{font-size:13px;line-height:1.65;color:rgba(240,232,159,.8)}
.quiz-card{background:rgba(66,37,29,.5);border:1px solid rgba(240,232,159,.12);border-radius:12px;padding:20px;margin-bottom:18px}
.quiz-num{font-family:'DM Mono',monospace;font-size:11px;color:var(--orange);letter-spacing:1px;text-transform:uppercase;margin-bottom:8px}
